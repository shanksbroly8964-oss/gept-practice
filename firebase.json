{
  "hosting": {
    "site": "gept-goku",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "_prompts/**",
      "_logs/**",
      "_ollama/**",
      "e2e/**",
      "tests/**",
      "package.json",
      "package-lock.json",
      "playwright.config.*",
      "nul",
      "DONE_*.md",
      "QA_REPORT_*.md",
      "E2E_REPORT.md",
      "FIREBASE_SETUP.md",
      "VERIFY_REPORT.md",
      "PWA_LOGIN_REPORT.md",
      "firestore.rules",
      "evidence/**"
    ],
    "headers": [
      {
        "source": "**/@(sw.js|*.html)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
